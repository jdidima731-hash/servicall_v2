{
  "name": "servicall-v2.0",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "generate-css": "node server/scripts/generate-css.cjs",
    "dev": "npm run generate-css && NODE_ENV=development tsx watch server/_core/index.ts",
    "build": "NODE_OPTIONS='--max-old-space-size=8192' vite build && pnpm exec esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "check-only": "pnpm run type-check && pnpm run lint",
    "start": "NODE_ENV=production node dist/index.js",
    "docker:start": "sh entrypoint.sh node dist/index.js",
    "check": "pnpm run type-check && pnpm run lint",
    "type-check": "NODE_OPTIONS='--max-old-space-size=4096' tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "lint": "NODE_OPTIONS='--max-old-space-size=4096' eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "test:client": "vitest run --config vitest.config.ts",
    "test:server": "vitest run --config vitest.server.config.ts",
    "test": "pnpm test:client && pnpm test:server",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "db:push": "drizzle-kit push",
    "db:migrate": "tsx server/scripts/migrate.ts",
    "db:generate": "drizzle-kit generate",
    "db:reset": "tsx server/scripts/db-reset.ts",
    "db:setup": "npm run db:reset && npm run db:push && npm run seed",
    "seed": "tsx server/scripts/seed.ts",
    "seed:complete": "tsx server/scripts/seed-complete.ts",
    "seed:auth": "tsx server/scripts/seed-auth.ts",
    "seed:audit": "tsx server/seed-audit.ts",
    "admin:init": "tsx server/scripts/init-admin.ts",
    "secrets:generate": "tsx server/scripts/generate-secrets.ts",
    "rls:apply": "tsx server/scripts/apply-rls.ts",
    "test:rls": "vitest run server/tests/rls-isolation.test.ts",
    "shadow-agent:run": "tsx server/scripts/shadow-agent-cron.ts",
    "test:shadow-agent": "vitest run server/tests/shadow-agent.test.ts",
    "test:load": "k6 run server/tests/load/api-stress.js",
    "test:load:report": "k6 run --summary-export=load-report.json server/tests/load/api-stress.js",
    "ci:check": "bash scripts/ci-quality-check.sh",
    "build:clean": "bash scripts/clean-build.sh",
    "build:prod": "rm -rf dist .tsbuildinfo && pnpm run build"
  },
