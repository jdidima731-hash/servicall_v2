# Servicall v2.0 - Configuration Environment Variables
# Copier ce fichier en .env et modifier les valeurs

# Application
NODE_ENV=development
PORT=3000
APP_NAME=Servicall
APP_URL=http://localhost:3000
API_URL=http://localhost:3000/api
CLIENT_URL=http://localhost:5173

# Database (NeonDB - PostgreSQL serverless)
DATABASE_URL=postgresql://user:password@ep-servicall.aws.neon.tech/servicall?sslmode=require
DIRECT_URL=postgresql://user:password@ep-servicall.aws.neon.tech/servicall

# Security & Authentication
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars
SESSION_SECRET=change-this-to-another-random-string
ENCRYPTION_KEY=32-character-encryption-key-here
BCRYPT_ROUNDS=12

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Redis (for caching and sessions)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Twilio (for calls)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Stripe (for payments)
STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email (Resend)
RESEND_API_KEY=re_your_api_key
ADMIN_EMAIL=admin@servicall.com
SUPPORT_EMAIL=support@servicall.com

# Monitoring & Logging
SENTRY_DSN=https://your-sentry-dsn.ingest.sentry.io/123456
LOGTAIL_TOKEN=your-logtail-token
LOG_LEVEL=debug

# Rate Limiting
RATE_LIMIT_WINDOW=900000  # 15 minutes in milliseconds
RATE_LIMIT_MAX=100        # requests per window

# File Upload
MAX_FILE_SIZE=10485760    # 10MB in bytes
UPLOAD_DIR=./uploads
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# Feature Flags
ENABLE_MFA=false
ENABLE_ANALYTICS=true
ENABLE_WEBSOCKETS=true
ENABLE_FILE_UPLOADS=true
