# Servicall V2.0 - Configuration Environnement (Exemple)
# Copiez ce fichier vers .env et remplissez les valeurs

# --- CONFIGURATION SERVEUR ---
NODE_ENV=production
PORT=3000
APP_URL=https://votre-domaine.com
ALLOWED_ORIGINS=https://votre-domaine.com,http://localhost:3000

# --- BASE DE DONNÉES (PostgreSQL recommandé pour la prod) ---
# Format: postgresql://user:password@localhost:5432/servicall_db
DATABASE_URL=postgresql://postgres:password@localhost:5432/servicall_db
DISABLE_DB=false

# --- REDIS (Obligatoire pour le rate limiting et les files d'attente) ---
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
DISABLE_REDIS=false

# --- SÉCURITÉ (Générez des clés de 64 caractères hexadécimaux) ---
# Utilisez: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
SESSION_SECRET=
CSRF_SECRET=
COOKIE_SECRET=
ENCRYPTION_KEY=
ENCRYPTION_SALT=
MASTER_KEY=
WEBHOOK_SECRET=

# --- IA (OPENAI) ---
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1

# --- TÉLÉPHONIE (TWILIO) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_TWIML_APP_SID=
TWILIO_PHONE_NUMBER=
TWILIO_API_KEY=
TWILIO_API_SECRET=

# --- PAIEMENTS (STRIPE) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- EMAILS (SMTP / RESEND) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
RESEND_API_KEY=

# --- STOCKAGE (AWS S3) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=

# --- OBSERVABILITÉ ---
SENTRY_DSN=
MODE_TEST=false
